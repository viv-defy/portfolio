---
layout: null
permalink: /notes/search.json
---
[
{% assign notes = site.notes | sort: "date" | reverse %}
{% for note in notes %}
  {
    "id": {{ forloop.index0 }},
    "title": {{ note.title | jsonify }},
    "url": {{ note.url | jsonify }},
    "date": {{ note.date | date: "%Y-%m-%d" | jsonify }},
    "tags": {{ note.tags | jsonify }},
    "content": {{ note.content | strip_html | strip_newlines | replace: "\t"," " | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
